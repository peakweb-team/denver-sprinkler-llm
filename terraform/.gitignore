# Terraform state and working files
*.tfstate
*.tfstate.backup
.terraform/
# Note: .terraform.lock.hcl IS committed per Terraform best practices

# Variable files with real values (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
