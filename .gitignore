# Environment
.env
.env.local

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Model artifacts (large files — use S3)
models/*/
models/*.bin
models/*.gguf
models/*.safetensors
models/*.pt

# Training artifacts
logs/
*.log
wandb/
runs/
checkpoints/

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl
terraform/terraform.tfvars

# Transcripts (keep .gitkeep, ignore saved conversations)
data/transcripts/*.json

# OS
.DS_Store

# Quantization caches (cloned repos for BitNet and llama.cpp)
.bitnet-cache/
.llama-cpp-cache/

# Claude config is baked into the Docker image at build time
# but don't track the copied source in git
.devcontainer/claude-config/
