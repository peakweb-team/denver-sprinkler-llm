# AWS credentials (required for Terraform and S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# GitHub PAT (fine-grained, scoped to peakweb-team org)
# Required for autonomous gh CLI usage (PRs, issue comments, pushes)
# Create at: https://github.com/settings/tokens?type=beta
# Scopes needed: repo (read/write), issues (read/write), pull requests (read/write)
GH_TOKEN=

# Anthropic API key (optional — only needed for issue #5 synthetic Q&A generation)
# If using Claude Code with OAuth login, this is not required.
ANTHROPIC_API_KEY=
